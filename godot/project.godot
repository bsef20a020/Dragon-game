; Engine configuration file.
; Dragon Flight — Godot 4 edition (ported from the Phaser/TypeScript build).

config_version=5

[application]

config/name="Dragon Flight"
config/description="Fast runs. Sharp gates. Fire on command."
run/main_scene="res://scenes/Menu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameData="*res://scripts/game_data.gd"
SaveData="*res://scripts/save_data.gd"
Audio="*res://scripts/audio.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

